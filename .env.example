# Ptt-Alertor 本地開發環境變數範本
# 複製成 .env（或 source 進 shell）後再啟動程式
# cp .env.example .env

# ===== 必要（不設會無法啟動或運作異常） =====

# Redis 連線（搭配 docker-compose.dev.yml）
REDIS_ENDPOINT=localhost
REDIS_PORT=6379

# DynamoDB Local endpoint（搭配 docker-compose.dev.yml）
# 注意：這個變數名叫 DB_CONNECTION 但實際放的是 DynamoDB HTTP endpoint
DB_CONNECTION=http://localhost:8000

# 配合 .aws/credentials 的假憑證
AWS_REGION=us-east-1

# 高優先看板（CSV；至少填一個避免切分出空字串造成初始化異常）
BOARD_HIGH=Gossiping

# 管理 API 的 Basic Auth（POST /users、/broadcast 等會檢查）
AUTH_USER=admin
AUTH_PW=admin

# 給 controllers/index.go、shorturl 用的站台網址
APP_HOST=http://localhost:9090
APP_WS_HOST=ws://localhost:9090

# ===== 選用（不設時對應頻道不會送訊息，但程式可跑） =====

# Telegram Bot（本地不測 Telegram 可留空，但 main.go 會註冊 webhook 路徑，建議給個假值）
TELEGRAM_TOKEN=dummy

# LINE Bot
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESSTOKEN=
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=

# Facebook Messenger
MESSENGER_ACCESSTOKEN=
MESSENGER_VERIFYTOKEN=

# Mailgun（寄信用）
MAILGUN_DOMAIN=
MAILGUN_APIKEY=
MAILGUN_PUBLIC_APIKEY=

# S3 靜態資源 URL 前綴（不打真實 S3，只是前端顯示用）
S3_DOMAIN=
